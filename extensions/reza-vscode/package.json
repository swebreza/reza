{
  "name": "reza-vscode",
  "displayName": "Reza — Code Graph",
  "description": "Interactive code knowledge graph with live session awareness for reza projects.",
  "version": "0.3.0",
  "publisher": "swebreza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/swebreza/reza"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": ["graph", "code-map", "reza", "llm", "session"],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.reza/context.db",
    "workspaceContains:.REZA/context.db",
    "onCommand:reza.showGraph",
    "onCommand:reza.initProject",
    "onCommand:reza.initAndBuild",
    "onCommand:reza.buildGraph",
    "onCommand:reza.startTracking"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reza.showGraph",
        "title": "Reza: Show Code Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "reza.showImpact",
        "title": "Reza: Show Blast Radius"
      },
      {
        "command": "reza.buildGraph",
        "title": "Reza: Build / Refresh Graph"
      },
      {
        "command": "reza.initProject",
        "title": "Reza: Initialize Project (reza init)"
      },
      {
        "command": "reza.initAndBuild",
        "title": "Reza: Initialize & Build Graph"
      },
      {
        "command": "reza.startTracking",
        "title": "Reza: Start Auto-Tracking (watch + hooks)"
      },
      {
        "command": "reza.refreshGraph",
        "title": "Reza: Refresh Graph View"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "reza.showGraph",
          "group": "navigation",
          "when": "resourceExtname =~ /\\.(py|ts|tsx|js|jsx|go|rs|java|rb|cs)$/"
        }
      ]
    },
    "configuration": {
      "title": "Reza Graph",
      "properties": {
        "reza.rezaPath": {
          "type": "string",
          "default": "reza",
          "description": "Path to the reza CLI executable."
        },
        "reza.nodeLimit": {
          "type": "number",
          "default": 800,
          "description": "Maximum nodes to display in the graph (0 = no limit)."
        },
        "reza.defaultNodeKinds": {
          "type": "string",
          "default": "Class,Function,Test",
          "description": "Comma-separated node kinds to show by default."
        },
        "reza.refreshIntervalMs": {
          "type": "number",
          "default": 3000,
          "description": "Session state refresh interval in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json && node build.js",
    "watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext ts",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
